{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fln.dev/schema/signed_claim-0.1.0.json",
  "title": "SignedClaim",
  "description": "Ed25519 signature over canonical thesis bytes. ``signer`` and ``signature`` are byte arrays (RFC 8032).",
  "type": "object",
  "required": ["payload", "signer", "signature"],
  "additionalProperties": false,
  "properties": {
    "payload": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 255 },
      "description": "Canonical bytes of the signed thesis."
    },
    "signer": {
      "type": "array",
      "minItems": 32,
      "maxItems": 32,
      "items": { "type": "integer", "minimum": 0, "maximum": 255 },
      "description": "Ed25519 public key (32 bytes)."
    },
    "signature": {
      "type": "array",
      "minItems": 64,
      "maxItems": 64,
      "items": { "type": "integer", "minimum": 0, "maximum": 255 },
      "description": "Ed25519 signature (64 bytes)."
    }
  }
}
